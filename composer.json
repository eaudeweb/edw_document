{
    "name": "eaudeweb/edw_document",
    "type": "drupal-module",
    "description": "Provides a Drupal Document to store organisational multilingual structured PDF/Word etc.\n\n",
    "license": "GPL-2.0-or-later",
    "minimum-stability": "dev",
    "homepage": "https://github.com/eaudeweb/edw_modules",
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        },
        {
            "type": "git",
            "url": "https://github.com/eaudeweb/edw_utilities.git"
        }
    ],
    "support": {
        "source": "https://github.com/eaudeweb/edw_document"
    },
    "authors": [
        {
            "name": "Daniela Eremia",
            "email": "dani.eremia@yahoo.com"
        }
    ],
    "require": {
        "drupal/core": "^10.3 || ^11",
        "drupal/better_exposed_filters": "^7.0",
        "drupal/entity_browser": "^2.13",
        "drupal/file_delete": "^3.0",
        "drupal/file_replace": "^1.5",
        "drupal/file_to_media": "^1.0",
        "drupal/search_api_solr":"^4.3",
        "drupal/select2": "^2.0",
        "drupal/views_bulk_operations": "^4.3",
        "eaudeweb/edw_utilities": "^1.0"
    },
    "extra": {
        "composer-exit-on-patch-failure": true,
        "patches": {
            "drupal/entity_reference_revisions": {
                "#2799479 - Views doesn't recognize relationship to host": "https://www.drupal.org/files/issues/2024-08-24/entity_reference_revisions-2799479-231--no-tests.patch"
            }
        }
    }
}
